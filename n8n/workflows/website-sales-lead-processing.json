            { "id": "Angebotswert EUR", "displayName": "Angebotswert EUR", "required": false, "defaultMatch": false, "display": true, "type": "number", "canBeUsedToMatch": true },
            { "id": "Opt-out", "displayName": "Opt-out", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Notizen", "displayName": "Notizen", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Quell-URL", "displayName": "Quell-URL", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Erstellt am", "displayName": "Erstellt am", "required": false, "defaultMatch": false, "display": true, "type": "dateTime", "canBeUsedToMatch": true },
            { "id": "Aktualisiert am", "displayName": "Aktualisiert am", "required": false, "defaultMatch": false, "display": true, "type": "dateTime", "canBeUsedToMatch": true }
          ]
        },
        "options": {}
      },
      "id": "append-crm-lead",
      "name": "Append Lead to CRM",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.6,
      "position": [-130, 0],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "qghI4J00QviooTnf",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "resource": "draft",
        "operation": "create",
        "subject": "={{ $('Enforce Draft Only').first().json.draft.subject }}",
        "emailType": "text",
        "message": "={{ $('Enforce Draft Only').first().json.draft.body }}",
        "options": {
          "sendTo": "={{ $('Enforce Draft Only').first().json.draft.to }}"
        }
      },
      "id": "create-gmail-draft",
      "name": "Create Gmail Draft",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [130, 0],
      "credentials": {
        "gmailOAuth2": {
          "id": "aUXrUPBPz7ZPYXF9",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ crm_logged: true, draft_created: true, draft_id: $json.id || null, sent: false, approval_status: 'pending' }) }}",
        "options": {
          "responseCode": 201
        }
      },
      "id": "return-draft-status",
      "name": "Return Approval Status",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.4,
      "position": [390, 0]
    }
  ],
  "connections": {
    "Receive Qualified Lead": {
      "main": [[{"node": "Enforce Draft Only", "type": "main", "index": 0}]]
    },
    "Enforce Draft Only": {
      "main": [[{"node": "Append Lead to CRM", "type": "main", "index": 0}]]
    },
    "Append Lead to CRM": {
      "main": [[{"node": "Create Gmail Draft", "type": "main", "index": 0}]]
    },
    "Create Gmail Draft": {
      "main": [[{"node": "Return Approval Status", "type": "main", "index": 0}]]
    }
