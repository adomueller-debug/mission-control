{
  "name": "Mission Control – CRM Lead & Gmail Draft",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mission-control-sales-lead",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "sales-lead-webhook",
      "name": "Receive Qualified Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [-620, 0],
      "webhookId": "mission-control-sales-lead"
    },
    {
      "parameters": {
        "jsCode": "const input = $json.body ?? $json;\nif (input.send === true) throw new Error('Automatischer E-Mail-Versand ist gesperrt.');\nif (!input.lead?.id || !input.lead?.name) throw new Error('Lead ist unvollständig.');\nif (!input.draft?.to || !input.draft?.subject || !input.draft?.body) throw new Error('E-Mail-Entwurf ist unvollständig.');\nreturn [{ json: { ...input, send: false, approval_status: 'pending' } }];"
      },
      "id": "validate-draft-only",
      "name": "Enforce Draft Only",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-390, 0]
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "value": "1uCKDobkcfjjOOmRUGeUVCwtAW5ddw49Smo7nWz9hysY",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Leads",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Lead-ID": "={{ $json.lead.id }}",
            "Unternehmen": "={{ $json.lead.name }}",
            "Branche": "={{ $json.lead.category }}",
            "Stadt": "={{ $json.lead.city }}",
            "Website": "={{ $json.lead.website }}",
            "Website-Qualität": "={{ !$json.lead.website ? 'Keine Website' : ($json.lead.website_score < 40 ? 'Schlecht' : ($json.lead.website_score < 60 ? 'Veraltet' : ($json.lead.website_score < 80 ? 'Akzeptabel' : 'Gut'))) }}",
            "Score": "={{ $json.lead.opportunity_score }}",
            "Ansprechpartner": "",
            "E-Mail": "={{ $json.lead.email }}",
            "Telefon": "",
            "Quelle": "OpenStreetMap",
            "Status": "Kontakt vorbereitet",
            "Zugewiesener Agent": "FLOW",
            "Nächste Aktion": "Entwurf prüfen und freigeben",
            "Kontaktfreigabe": "Nur Entwurf",
            "Angebotswert EUR": 350,
            "Opt-out": "Nein",
            "Notizen": "={{ [$json.lead.address, ...$json.lead.reasons].filter(Boolean).join('; ') }}",
            "Quell-URL": "={{ $json.lead.source_url }}",
            "Erstellt am": "={{ $now }}",
            "Aktualisiert am": "={{ $now }}"
          },
          "matchingColumns": ["Lead-ID"],
          "schema": [
            { "id": "Lead-ID", "displayName": "Lead-ID", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Unternehmen", "displayName": "Unternehmen", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
